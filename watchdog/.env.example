# ── CAST AI Authentication ────────────────────────────────────────
# API key (required for LLM proxy; also used as CAST AI auth fallback)
CASTAI_API_KEY=

# JWT and IAP tokens are auto-loaded from ~/.castai/ if not set here:
#   ~/.castai/credentials.json  → jwt_token
#   ~/.castai/iap_token.json    → iap_token
# Uncomment only if you want to override the file-based defaults:
# CASTAI_JWT_TOKEN=
# CASTAI_IAP_TOKEN=

# ── CAST AI Organization ─────────────────────────────────────────
CASTAI_ORG_ID=
CASTAI_MCP_URL=https://castai-mcp.prod-master.cast.ai/mcp
# CASTAI_API_URL=https://api.cast.ai

# ── Cluster ──────────────────────────────────────────────────────
WATCHDOG_CLUSTER_IDS=

# ── LLM Evaluator ───────────────────────────────────────────────
# LLM_API_KEY=              # falls back to CASTAI_API_KEY if unset
LLM_BASE_URL=https://llm.kimchi.dev/openai/v1
WATCHDOG_MODEL=minimax-m2.7
# WATCHDOG_FALLBACK_MODEL=kimi-k2.6

# ── Slack ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
# SLACK_CHANNEL=#castai_grip_security_ext

# ── Runtime ──────────────────────────────────────────────────────
WATCHDOG_DRY_RUN=false
WATCHDOG_LOG_LEVEL=INFO
# WATCHDOG_STATE_FILE=watchdog_state.json
